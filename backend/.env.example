# Social Emblue AI — Environment Variables
# Copy to .env and fill in all values before running

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Production example:
# FRONTEND_URL=https://emblue-social-ai.vercel.app
API_BASE_URL=http://localhost:3001
ENABLE_SWAGGER=true
DISABLE_AUTOMATION_AUTOSTART=false

# ── ANTHROPIC (REQUIRED) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SUPABASE / POSTGRESQL (REQUIRED) ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://[PROJECT].supabase.co/auth/v1/.well-known/jwks.json
# Optional legacy fallback only if your Supabase project still signs JWTs with HS256.
SUPABASE_JWT_SECRET=
SUPERADMIN_EMAILS=founder@yourdomain.com
SUPER_ADMIN_EMAIL=founder@yourdomain.com
SUPER_ADMIN_PASSWORD=change-this-before-production
OAUTH_STATE_SECRET=replace-with-a-long-random-string

# ── META (INSTAGRAM + FACEBOOK) ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://your-railway-url/api/v1/auth/meta/callback
META_VERIFY_TOKEN=your-random-webhook-verify-string
META_PAGE_ACCESS_TOKEN=

# ── X (TWITTER) ───────────────────────────────────────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://your-railway-url/api/v1/auth/x/callback
X_BEARER_TOKEN=
X_OAUTH_TOKEN=

# ── TIKTOK ────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-railway-url/api/v1/auth/tiktok/callback
TIKTOK_ACCESS_TOKEN=
# Optional — OAuth scopes requested at TikTok connect time (comma-separated).
# Defaults to "user.info.basic,video.list". Some scopes require TikTok app review.
# TIKTOK_SCOPES=

# ── OPENAI (for deduplication embeddings — optional at MVP) ──────────────────
OPENAI_API_KEY=

# ── RESEND (EMAIL) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Social Emblue AI <reports@yourdomain.com>

# ── CLOUDINARY (IMAGES) ───────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── REDIS / BULLMQ (optional — uses setInterval scheduler if not set) ─────────
# Get free Redis from upstash.com
REDIS_URL=redis://default:password@hostname:6379

# ── APIFY (MONTH 2 SCRAPER) ───────────────────────────────────────────────────
APIFY_API_TOKEN=

# ── TRACKED LINKS ─────────────────────────────────────────────────────────────
LINK_BASE_URL=https://seai.link
